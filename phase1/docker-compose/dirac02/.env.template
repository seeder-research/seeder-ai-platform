# DIRAC02_IP and FEYNMAN_IP are used by docker-compose.yml in this same
# directory to substitute into `ports:` host-IP bindings and WireGuard's
# PEERDNS — both require a literal IP.
DIRAC02_IP=<replace-with-actual-ip>
FEYNMAN_IP=<replace-with-actual-ip>
REDIS_URL=redis://dirac02:6379
WG_PEERS=3
INTERNAL_DOMAIN=ai.internal
