# BOSE01_IP and FEYNMAN_IP are used by docker-compose.yml in this same
# directory to substitute into `ports:` host-IP bindings and the LiteLLM
# database connection string. ports: bindings require a literal IP.
BOSE01_IP=<replace-with-actual-ip>
FEYNMAN_IP=<replace-with-actual-ip>
POSTGRES_PASSWORD=<secret>
LITELLM_MASTER_KEY=<secret>
